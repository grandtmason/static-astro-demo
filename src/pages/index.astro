---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
const allPlants = await getCollection('species');
const plants = allPlants.map(p => ({
  ...p,
  slug: p.id.replace('/index', '').replace('.md', ''),
}));
---
<Layout title="South African Botanical Registry">
<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
:root {
  --green: #1A3A2A; --gold: #B8860B; --parch: #F9F8F4;
  --ink: #2F2F2F; --muted: #7A7A7A; --sage: #9DB8A8; --border: #E0DED7;
  --display: 'Cormorant Garamond', Georgia, serif;
  --sans: sans-serif; --serif: 'EB Garamond', Georgia, serif;
}
body { background: var(--parch); font-family: var(--serif); color: var(--ink); }
.top-bar {
  background: var(--green); border-bottom: 2px solid var(--gold);
  padding: 12px 32px; text-align: center;
}
.top-bar h1 {
  font-family: var(--sans); font-size: 9px; letter-spacing: 5px;
  text-transform: uppercase; color: var(--sage); font-weight: 400;
}
.hero {
  text-align: center; padding: 60px 24px 40px;
  border-bottom: 1px solid var(--border);
}
.hero-title {
  font-family: var(--display); font-size: clamp(2.4rem, 5vw, 4rem);
  font-weight: 300; font-style: italic; color: var(--green);
  line-height: 1.1; margin-bottom: 12px;
}
.hero-sub {
  font-family: var(--sans); font-size: 9px; letter-spacing: 3px;
  text-transform: uppercase; color: var(--muted); margin-bottom: 32px;
}
.hero-intro {
  max-width: 560px; margin: 0 auto; font-size: 1rem;
  line-height: 1.8; color: var(--ink);
}
.registry {
  max-width: 1100px; margin: 0 auto; padding: 40px 24px 80px;
}
.registry-title {
  font-family: var(--sans); font-size: 7px; letter-spacing: 3px;
  text-transform: uppercase; color: var(--muted);
  border-bottom: 1px solid var(--border); padding-bottom: 8px; margin-bottom: 20px;
}
.plant-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
  gap: 1px;
  background: var(--border);
  border: 1px solid var(--border);
}
.plant-card {
  background: var(--parch);
  text-decoration: none;
  display: flex;
  flex-direction: column;
  transition: background .12s;
}
.plant-card:hover { background: #fff; }
.plant-card:hover .plant-card-img img {
  transform: scale(1.04);
}
.plant-card-img {
  width: 100%;
  aspect-ratio: 4/3;
  overflow: hidden;
  background: var(--green);
}
.plant-card-img img {
  width: 100%; height: 100%;
  object-fit: cover;
  display: block;
  transition: transform .4s ease;
}
.plant-card-img-empty {
  width: 100%;
  aspect-ratio: 4/3;
  background: var(--green);
  display: flex; align-items: center; justify-content: center;
}
.plant-card-img-empty span {
  font-family: var(--sans); font-size: 8px; letter-spacing: 2px;
  text-transform: uppercase; color: var(--sage);
}
.plant-card-body { padding: 14px 16px; flex: 1; }
.plant-card-name {
  font-family: var(--display); font-size: 1.2rem; font-style: italic;
  font-weight: 300; color: var(--gold); line-height: 1; margin-bottom: 4px;
}
.plant-card-sci {
  font-family: var(--sans); font-size: 7px; letter-spacing: 2px;
  text-transform: uppercase; color: var(--muted); margin-bottom: 6px;
}
.plant-card-desc {
  font-family: var(--sans); font-size: 8px; color: var(--muted);
  line-height: 1.5; display: -webkit-box; -webkit-line-clamp: 3;
  -webkit-box-orient: vertical; overflow: hidden;
}
.footer {
  background: var(--green); border-top: 2px solid var(--gold);
  padding: 16px 32px; text-align: center;
}
.footer p {
  font-family: var(--sans); font-size: 8px; letter-spacing: 2px;
  text-transform: uppercase; color: var(--sage);
}
</style>

<div class="top-bar">
  <h1>South African Botanical Registry</h1>
</div>

<div class="hero">
  <div class="hero-title">South African Botanical Registry</div>
  <div class="hero-sub">24 Indigenous Species · Verified Data · Commercial Intelligence</div>
  <p class="hero-intro">
    The definitive reference for South Africa's botanical heritage. Each entry documents
    the scientific record, indigenous knowledge, commercial data, and trade intelligence
    for the country's most significant plant species.
  </p>
</div>

<div class="registry">
  <div class="registry-title">{plants.length} Species Registered</div>
  <div class="plant-grid">
    {plants.map(plant => (
      <a href={`/species/${plant.slug}`} class="plant-card">
        {plant.data.image ? (
          <div class="plant-card-img">
            <img src={plant.data.image} alt={plant.data.name} loading="lazy" />
          </div>
        ) : (
          <div class="plant-card-img-empty">
            <span>Image coming soon</span>
          </div>
        )}
        <div class="plant-card-body">
          <div class="plant-card-name">{plant.data.name}</div>
          <div class="plant-card-sci">{plant.data.scientific_name}</div>
          <div class="plant-card-desc">{plant.data.description}</div>
        </div>
      </a>
    ))}
  </div>
</div>

<div class="footer">
  <p>South African Botanical Registry · southafricanbotanical.org.za</p>
</div>

</Layout>
