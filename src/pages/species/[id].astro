---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import ProvinceMap from '../../components/ProvinceMap.astro';

export async function getStaticPaths() {
  const allPlants = await getCollection('species');
  return allPlants.map(plant => ({
    params: { id: plant.id.replace('/index', '').replace('.md', '') },
    props: { plant },
  }));
}

const { plant } = Astro.props;
const d = plant.data;
const m = d.medicinal_properties ?? {};
const cv = d.cultivation ?? {};
const ik = d.indigenous_knowledge ?? '';
const q = d.quadrants ?? {};
const cn = d.common_names ?? {};
const images = Array.isArray(d.images) ? d.images : d.image ? [{ src: d.image, credit: '' }] : [];
const slug = plant.id.replace('/index', '').replace('.md', '');

// ... [Keep your original COMMON_NAMES, PLANT_STATS, and PLANT_PROTECTION dictionaries here] ...
---
<Layout title={`${d.name} | South African Botanical Registry`}>
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  :root { --green: #1A3A2A; --gold: #B8860B; --parch: #F9F8F4; --ink: #2F2F2F; --muted: #7A7A7A; --sage: #9DB8A8; --border: #E0DED7; --serif: 'EB Garamond', Georgia, serif; --display: 'Cormorant Garamond', Georgia, serif; --sans: sans-serif; }
  body { background: var(--parch); color: var(--ink); font-family: var(--serif); }
  .portal { display: flex; flex-direction: column; min-height: 100vh; }
  .content-wrap { flex: 1; overflow-y: auto; overflow-x: hidden; }
  .top-bar { background: var(--green); border-bottom: 2px solid var(--gold); padding: 9px 28px; display: flex; align-items: center; justify-content: center; position: relative; }
  .top-bar-back { color: var(--gold); font-family: var(--sans); font-size: 24px; text-decoration: none; position: absolute; left: 28px; }
  .top-bar-title { font-family: var(--sans); font-size: 10px; letter-spacing: 4px; text-transform: uppercase; color: var(--sage); text-decoration: none; }
  .plant-band { background: var(--parch); display: flex; flex-direction: column; align-items: center; padding: 12px 20px 0; }
  .plant-name { font-family: var(--display); font-size: 2.4rem; font-weight: 300; font-style: italic; color: var(--gold); line-height: 1; margin-bottom: 4px; }
  .plant-sci { font-family: var(--sans); font-size: 10px; letter-spacing: 5px; text-transform: uppercase; color: var(--muted); }
  /* Ensure image wrap maintains square shape and centers content */
  .carousel-wrap { width: 186px; height: 186px; background: var(--green); overflow: hidden; position: relative; margin: 8px; }
  .carousel-img { width: 100%; height: 100%; object-fit: cover; display: none; }
  .carousel-img.active { display: block; }
</style>

<div class="portal">
  <div class="top-bar">
    <a href="/" class="top-bar-back">←</a>
    <a href="/" class="top-bar-title">South African Botanical Registry</a>
  </div>
  <div class="plant-band">
    <h1 class="plant-name">{d.name}</h1>
    <p class="plant-sci">{d.scientific_name}</p>
  </div>
  <div class="content-wrap">
    <!-- ... (Keep your rest of your layout panels here) ... -->
  </div>
</div>
</Layout>
