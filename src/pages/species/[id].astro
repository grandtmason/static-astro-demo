  'rooibos':              { gi_year: 'GI 2021', gi_status: 'EU Geographical Indication — South Africa sole legally recognised producer. Name protected in European markets. SA Rooibos Council governs GI compliance.', bsa_year: 'BSA 2019', bsa_status: 'Khoisan Benefit-Sharing Agreement — ongoing royalties paid to traditional knowledge holders from industry revenues. Globally cited as the model for ethical botanical trade.', organic: '35% of total production certified organic — highest proportion of any South African botanical export crop. Organic commands significant price premium.', wild_harvest: 'Fully cultivated — no wild harvest. Commercial production entirely from planted farms in the Cederberg GI zone.' },
  'sutherlandia':         { gi_year: 'No GI', gi_status: 'No GI protection. Named after a Scottish botanist who never visited Africa — one of many colonial naming ironies in the registry.', bsa_year: 'No BSA', bsa_status: 'No formal agreement. Khoikhoi, Xhosa, Cape Malay and Afrikaner healing traditions all contributed to the kankerbos knowledge base — no single rights holder.', organic: 'Certified organic production available from Western Cape producers.', wild_harvest: 'Mix of cultivation and wild harvest across Western and Northern Cape.' },
  'uzara':                { gi_year: 'No GI', gi_status: 'No GI protection. German Commission E monograph holder — one of only a handful of African plants with full European pharmaceutical status.', bsa_year: 'No BSA', bsa_status: 'No formal agreement. Zulu and Xhosa communities hold traditional knowledge. German pharmaceutical name preserved the African name — unusual in colonial botanical history.', organic: 'Small certified organic production available.', wild_harvest: 'Mix of cultivation and wild harvest. Cultivation essential as wild stock at risk.' },
  'wild-olive':           { gi_year: 'No GI', gi_status: 'No GI protection. Significant underutilised commercial potential. No formal industry association yet established.', bsa_year: 'No BSA', bsa_status: 'No formal agreement. Zulu communities associate umquma with spiritual protection. Knowledge distributed across multiple language communities.', organic: 'Small certified organic leaf extract production.', wild_harvest: 'Primarily wild-harvested leaves. No sustainability concerns at current minimal commercial scale.' },
  'wild-sage':            { gi_year: 'No GI', gi_status: 'No GI protection. Cape Malay culinary tradition is primary commercial driver. Undercommercialised relative to profile.', bsa_year: 'No BSA', bsa_status: 'No formal agreement. Khoikhoi knowledge partially preserved in Cape Malay cooking tradition — communities not formally recognised.', organic: 'Small certified organic production from Western Cape coastal fynbos.', wild_harvest: 'Primarily wild-harvested. No sustainability concerns at current scale.' },
};

const slug = plant.id.replace('/index', '').replace('.md', '');
const hardcodedNames = COMMON_NAMES[slug] ?? {};
const displayNames = Object.keys(hardcodedNames).length > 0 ? Object.entries(hardcodedNames) : sortedNames;
const stats = PLANT_STATS[slug] ?? { production: '—', revenue: '—', markets: '—', livelihoods: '—' };
const protection = PLANT_PROTECTION[slug] ?? { gi_year: 'GI 2021', gi_status: 'EU Geographical Indication — South Africa sole legally recognised producer.', bsa_year: 'BSA 2019', bsa_status: 'Khoisan Benefit-Sharing Agreement — ongoing royalties paid to traditional knowledge holders.', organic: '35% of total production certified organic.', wild_harvest: 'Fully cultivated — no wild harvest.' };
---

<Layout title={`${d.name} | South African Botanical Registry`} schema={jsonLd}>
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  :root {
    --green:   #1A3A2A;
    --gold:    #B8860B;
    --parch:   #F9F8F4;
    --ink:     #2F2F2F;
    --muted:   #7A7A7A;
    --sage:    #9DB8A8;
    --border:  #E0DED7;
    --serif:   'EB Garamond', Georgia, serif;
    --display: 'Cormorant Garamond', Georgia, serif;
    --sans:    sans-serif;
  }
  body { background: var(--parch); color: var(--ink); font-family: var(--serif); }
  .portal { display: flex; flex-direction: column; height: 100vh; overflow: hidden; }
  .top-bar { background: var(--green); border-bottom: 2px solid var(--gold); padding: 9px 28px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; position: relative; }
  .top-bar-back { color: var(--gold); font-family: var(--sans); font-size: 24px; text-decoration: none; line-height: 1; position: absolute; left: 28px; }
  .top-bar-title { font-family: var(--sans); font-size: 10px; letter-spacing: 4px; text-transform: uppercase; color: var(--sage); text-decoration: none; }
  .plant-band { background: var(--parch); display: flex; flex-direction: column; align-items: center; padding: 12px 20px 0; flex-shrink: 0; }
  .plant-name { font-family: var(--display); font-size: clamp(1.8rem, 2.5vw, 2.4rem); font-weight: 300; font-style: italic; color: var(--gold); line-height: 1; margin-bottom: 4px; }
  .plant-sci { font-family: var(--sans); font-size: 10px; letter-spacing: 5px; text-transform: uppercase; color: var(--muted); margin-bottom: 0; }
  .tabs-row { display: flex; width: 100%; margin-top: 10px; border-bottom: 1px solid var(--border); border-top: 1px solid var(--border); }
  .tab-btn { font-family: var(--sans); font-size: 10px; letter-spacing: 0.5px; text-transform: uppercase; background: var(--parch); color: var(--ink); border: none; border-right: 1px solid var(--border); border-bottom: 3px solid transparent; padding: 7px 2px; flex: 1; cursor: pointer; white-space: nowrap; transition: color .1s, background .1s; text-align: center; }
  .tab-btn:last-child { border-right: none; }
  .tab-btn:hover { color: var(--gold); background: #fff; }
  .tab-btn.active { background: #fff; color: var(--gold); border-bottom: 3px solid var(--gold); }
  .content-wrap { flex: 1; overflow-y: auto; overflow-x: hidden; }
  .tab-panel { display: none; }
  .tab-panel.active { display: block; }
  .ds-grid { display: grid; grid-template-columns: 202px 1fr; align-items: stretch; }
  .ds-left { border-right: 1px solid var(--border); display: flex; flex-direction: column; }
  .carousel-wrap { width: 186px; height: 186px; background: var(--green); position: relative; overflow: hidden; flex-shrink: 0; outline: 8px solid white; outline-offset: -8px; margin: 8px; }
  .carousel-img { width: 100%; height: 100%; object-fit: cover; display: none; }
  .carousel-img.active { display: block; }
  .carousel-empty { position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; font-family: var(--sans); font-size: 10px; letter-spacing: 2px; text-transform: uppercase; color: var(--sage); text-align: center; line-height: 1.8; padding: 0 16px; }
  .photo-credit { background: var(--parch); padding: 6px 10px; border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); }
  .photo-credit-lbl { font-family: var(--sans); font-size: 7.5px; letter-spacing: 2px; text-transform: uppercase; color: var(--sage); margin-bottom: 2px; }
  .photo-credit-val { font-family: var(--sans); font-size: 8.5px; color: var(--muted); line-height: 1.4; }
  .carousel-nav { display: flex; align-items: center; justify-content: space-between; padding: 3px 10px; background: var(--parch); border-bottom: 1px solid var(--border); }
  .c-arrow { background: none; border: none; font-size: 12px; color: var(--muted); padding: 0; cursor: pointer; line-height: 1; }
  .c-arrow:hover { color: var(--gold); }
  .c-count { font-family: var(--sans); font-size: 9px; color: var(--muted); }
  .names-wrap { padding: 8px; flex: 1; }
  .names-lbl { font-family: var(--sans); font-size: 8px; letter-spacing: 2px; text-transform: uppercase; color: var(--sage); padding-bottom: 4px; border-bottom: 1px solid var(--border); margin-bottom: 1px; }
  .name-row { display: grid; grid-template-columns: 62px 1fr; padding: 2.5px 0; border-bottom: 1px solid #F5F4F0; gap: 4px; align-items: start; }
  .name-row:last-child { border-bottom: none; }
  .n-lang { font-family: var(--sans); font-size: 8px; color: var(--sage); text-transform: uppercase; letter-spacing: .3px; padding-top: 1px; }
  .n-val { font-family: var(--serif); font-size: 12px; color: var(--ink); line-height: 1.3; }
  .n-val.nd { color: #C8C6BE; font-style: italic; font-size: 11px; }
  .ds-right { display: flex; flex-direction: column; }
  .id-three { display: grid; grid-template-columns: 1fr 1.4fr 1fr; border-bottom: 1px solid var(--border); }
  .id-cell { padding: 9px 14px; border-right: 1px solid var(--border); }
  .id-cell:last-child { border-right: none; }
  .block-lbl { font-family: var(--sans); font-size: 8px; letter-spacing: 2px; text-transform: uppercase; color: var(--sage); margin-bottom: 4px; }
  .id-val { font-family: var(--serif); font-size: 16px; color: var(--ink); }
  .id-val.it { font-style: italic; }
  .native-block { padding: 9px 14px; border-bottom: 1px solid var(--border); }
  .native-val { font-family: var(--serif); font-size: 14px; font-style: italic; color: var(--ink); line-height: 1.65; margin-top: 3px; }
  .stats-row { display: grid; grid-template-columns: 1fr 1fr 1fr 1fr; }
  .stat-cell { padding: 8px 14px; border-right: 1px solid var(--border); display: flex; flex-direction: column; justify-content: space-between; min-height: 58px; }
  .stat-cell:last-child { border-right: none; }
  .stat-val { font-family: var(--sans); font-size: 13px; font-weight: 600; letter-spacing: 0.3px; color: var(--gold); margin-top: auto; line-height: 1; }
  .prot-block { padding: 9px 0; }
  .prot-block-lbl { font-family: var(--sans); font-size: 8px; letter-spacing: 2px; text-transform: uppercase; color: var(--sage); margin-bottom: 6px; padding: 0 14px; }
  .prot-row { display: flex; align-items: stretch; padding: 4px 0; border-bottom: 1px solid #F5F4F0; }
  .prot-row:last-child { border-bottom: none; }
  .prot-badge { font-family: var(--sans); font-size: 7.5px; letter-spacing: .8px; text-transform: uppercase; padding: 5px 0; flex-shrink: 0; white-space: nowrap; background: var(--green); color: var(--sage); width: 90px; text-align: center; display: flex; align-items: center; justify-content: center; }
  .prot-text { font-family: var(--serif); font-size: 13px; color: var(--ink); line-height: 1.55; padding: 4px 14px; }
  .intro-block { padding: 10px 14px; border-bottom: none; }
  .intro-text { font-family: var(--serif); font-size: 13.5px; line-height: 1.78; color: var(--ink); margin-top: 4px; }
  .stats-map-row { display: grid; grid-template-columns: 40% 38% 22%; border-bottom: 1px solid var(--border); min-height: 280px; }
  .stats-col { display: flex; flex-direction: column; border-right: 1px solid var(--border); border-top: 1px solid var(--border); }
  .map-col { border-right: 1px solid var(--border); overflow: hidden; height: 100%; }
  .key-col { padding: 8px; display: flex; flex-direction: column; }
  .key-section-lbl { font-family: var(--sans); font-size: 7px; letter-spacing: 2px; text-transform: uppercase; color: var(--sage); margin-bottom: 5px; }
  .key-prov-row { display: flex; align-items: center; gap: 5px; margin-bottom: 3px; }
  .key-swatch { width: 10px; height: 10px; flex-shrink: 0; border: 0.5px solid rgba(0,0,0,0.1); }
  .key-abbr { font-family: var(--sans); font-size: 7px; letter-spacing: 1px; color: var(--green); font-weight: 500; width: 22px; flex-shrink: 0; }
  .key-name { font-family: var(--sans); font-size: 7px; color: var(--muted); line-height: 1.2; }
  .key-divider { border-top: 1px solid var(--border); margin: 6px 0; }
  .key-dot-row { display: flex; align-items: center; gap: 5px; margin-bottom: 4px; }
  .key-dot { width: 8px; height: 8px; background: var(--gold); border-radius: 50%; flex-shrink: 0; border: 1px solid #fff; }
  .key-dot-org { width: 8px; height: 8px; background: var(--gold); border-radius: 50%; flex-shrink: 0; border: 1px solid #fff; display: flex; align-items: center; justify-content: center; }
  .key-dot-inner { width: 3px; height: 3px; background: var(--green); border-radius: 50%; }
  .ds-lower { padding: 14px 16px; }
  .ds-row3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 14px; margin-bottom: 14px; }
  .ds-row2 { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; margin-bottom: 14px; }
  .ds-sec { border-top: 1px solid var(--border); padding-top: 8px; }
  .ds-sec-lbl { font-family: var(--sans); font-size: 9px; letter-spacing: 2px; text-transform: uppercase; color: var(--sage); margin-bottom: 6px; }
  .ds-list { padding-left: 14px; }
  .ds-list li { font-family: var(--serif); font-size: 13.5px; line-height: 1.55; color: var(--ink); margin-bottom: 2px; }
  .ds-val { font-family: var(--serif); font-size: 13.5px; line-height: 1.65; color: var(--ink); }
  .ik-block { background: var(--parch); border: 1px solid var(--border); padding: 13px 16px; margin-bottom: 14px; }
  .ik-lbl { font-family: var(--sans); font-size: 9px; letter-spacing: 2px; text-transform: uppercase; color: var(--sage); margin-bottom: 6px; }
  .ik-val { font-family: var(--serif); font-size: 14px; line-height: 1.8; color: var(--ink); font-style: normal; }
  .cards-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; padding: 16px; }
  .card { background: #fff; border: 1px solid var(--border); border-top: 2px solid var(--gold); padding: 16px 18px; }
  .card.dark { background: var(--green); border-top-color: var(--gold); }
  .c-tag   { font-family: var(--sans); font-size: 8px; letter-spacing: 2px; text-transform: uppercase; color: var(--gold); margin-bottom: 7px; }
  .c-tag-l { font-family: var(--sans); font-size: 8px; letter-spacing: 2px; text-transform: uppercase; color: var(--sage); margin-bottom: 7px; }
  .c-hl    { font-size: 15px; color: var(--ink); line-height: 1.45; margin-bottom: 6px; font-style: italic; }
  .c-hl-l  { font-size: 15px; color: var(--parch); line-height: 1.45; margin-bottom: 6px; font-style: italic; }
  .c-tsr   { font-family: var(--sans); font-size: 12px; color: var(--muted); line-height: 1.5; margin-bottom: 8px; }
  .c-tsr-l { font-family: var(--sans); font-size: 12px; color: var(--sage); line-height: 1.5; margin-bottom: 8px; }
  .c-summary   { display: none; font-size: 13.5px; line-height: 1.7; color: var(--ink); border-top: 1px solid var(--border); padding-top: 9px; margin-top: 7px; margin-bottom: 9px; }
  .c-summary.open { display: block; }
  .c-summary-l { display: none; font-size: 13.5px; line-height: 1.7; color: #D4C9B8; border-top: 1px solid rgba(255,255,255,.12); padding-top: 9px; margin-top: 7px; margin-bottom: 9px; }
  .c-summary-l.open { display: block; }
  .c-gate { display: none; margin-top: 6px; }
  .c-gate.open { display: block; }
  .c-email-row { display: flex; gap: 6px; margin-top: 6px; }
  .c-email-row input { flex: 1; padding: 5px 8px; font-family: var(--sans); font-size: 13px; border: 1px solid var(--border); background: var(--parch); color: var(--ink); outline: none; }
  .c-email-row input.dk { background: rgba(255,255,255,.1); border-color: rgba(184,134,11,.4); color: var(--parch); }
  .c-email-btn { padding: 5px 10px; font-family: var(--sans); font-size: 11px; letter-spacing: 1px; text-transform: uppercase; background: var(--gold); color: var(--green); border: none; cursor: pointer; font-weight: 600; }
  .c-sent { font-family: var(--sans); font-size: 12px; color: var(--gold); margin-top: 5px; display: none; }
  .c-read-btn { font-family: var(--sans); font-size: 8px; letter-spacing: 1px; text-transform: uppercase; border: none; cursor: pointer; padding: 0; background: transparent; margin-top: 5px; display: block; color: var(--ink); }
  .c-read-btn.read { color: var(--gold); }
  .site-footer { position: fixed; bottom: 0; left: 0; right: 0; background: var(--green); border-top: 2px solid var(--gold); display: flex; align-items: stretch; z-index: 100; }
  .ft-label { font-family: var(--sans); font-size: 14px; letter-spacing: 3px; text-transform: uppercase; color: var(--sage); padding: 12px 20px; display: flex; align-items: center; border-right: 1px solid rgba(184,134,11,.3); white-space: nowrap; }
  .ft-btns { display: flex; flex: 1; }
  .ft-btn { flex: 1; padding: 12px 8px; font-family: var(--sans); font-size: 20px; letter-spacing: 2px; text-transform: uppercase; text-align: center; cursor: pointer; border: none; background: transparent; color: var(--gold); transition: background .2s, color .2s; }
  .ft-btn:first-child { border-right: 1px solid rgba(184,134,11,.3); }
  .ft-btn:hover { background: var(--gold); color: var(--green); }
  .modal-overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,.5); z-index: 200; align-items: center; justify-content: center; }
  .modal-overlay.open { display: flex; }
  .modal { background: #fff; border-top: 3px solid var(--gold); padding: 32px 36px; width: 100%; max-width: 480px; position: relative; }
  .modal-close { position: absolute; top: 14px; right: 18px; background: none; border: none; font-size: 20px; cursor: pointer; color: var(--muted); }
  .modal h2 { font-family: var(--display); font-size: 1.5rem; font-style: italic; color: var(--green); margin-bottom: 6px; }
  .modal p { font-family: var(--sans); font-size: 13px; color: var(--muted); margin-bottom: 20px; line-height: 1.6; }
  .m-field { display: flex; flex-direction: column; gap: 4px; margin-bottom: 12px; }
  .m-field label { font-family: var(--sans); font-size: 10px; letter-spacing: 1.5px; text-transform: uppercase; color: var(--muted); }
  .m-field input, .m-field textarea { padding: 8px 10px; font-family: var(--sans); font-size: 13px; border: 1px solid var(--border); background: var(--parch); color: var(--ink); outline: none; width: 100%; }
  .m-field textarea { height: 80px; resize: vertical; }
  .m-submit { width: 100%; padding: 12px; background: var(--gold); color: var(--green); border: none; font-family: var(--sans); font-size: 11px; letter-spacing: 3px; text-transform: uppercase; font-weight: 600; cursor: pointer; margin-top: 8px; }
  .m-thanks { display: none; text-align: center; padding: 20px 0; font-family: var(--sans); font-size: 11px; color: var(--gold); letter-spacing: 1px; }
  @media (max-width: 680px) {
    .tabs-row { display: none; }
    .portal { padding-bottom: 72px; height: auto; overflow: visible; }
    .content-wrap { overflow: visible; }
    .explore-bar { padding: 7px 14px; display: flex; align-items: center; gap: 8px; background: #fff; border-bottom: 2px solid var(--gold); flex-shrink: 0; }
    .mob-back-txt { font-family: var(--sans); font-size: 8px; letter-spacing: 2px; text-transform: uppercase; color: var(--ink); background: none; border: none; cursor: pointer; padding: 0; white-space: nowrap; flex-shrink: 0; }
    .explore-pill { font-family: var(--sans); font-size: 8px; letter-spacing: 1.5px; text-transform: uppercase; color: var(--ink); border: 1px solid #C8C6BE; padding: 4px 12px; background: var(--parch); cursor: pointer; display: inline-flex; align-items: center; gap: 4px; }
    .explore-pill .pill-arrow { color: var(--gold); }
    .tab-pill { font-family: var(--sans); font-size: 8px; letter-spacing: 1.5px; text-transform: uppercase; color: var(--ink); border: 1px solid #C8C6BE; padding: 4px 12px; background: var(--parch); display: inline-block; }
    .mob-tab-list { display: flex; flex-direction: column; background: #fff; border-bottom: 2px solid var(--gold); flex-shrink: 0; }
    .mob-tab-row { width: 100%; padding: 10px 14px; font-family: var(--sans); font-size: 12px; letter-spacing: 2px; text-transform: uppercase; background: var(--parch); color: var(--ink); border: none; border-bottom: 1px solid var(--border); text-align: center; cursor: pointer; }
    .mob-tab-row:last-child { border-bottom: none; }
    .ds-grid { grid-template-columns: 1fr; }
    .ds-left { border-right: none; border-bottom: 1px solid var(--border); }
    .carousel-wrap { width: 100%; height: 240px; }
    .ds-row3 { grid-template-columns: 1fr; }
    .ds-row2 { grid-template-columns: 1fr; }
    .cards-grid { grid-template-columns: 1fr; }
    .stats-map-row { grid-template-columns: 1fr; min-height: auto; }
    .map-col { height: 200px; }
    .key-col { display: none; }
    .id-three { grid-template-columns: 1fr; }
    .id-three .id-cell { border-right: none; border-bottom: 1px solid var(--border); }
    .site-footer { flex-direction: column; }
    .ft-label { border-right: none; border-bottom: 1px solid rgba(184,134,11,.3); justify-content: center; }
    .ft-btns { flex-direction: row; }
  }
  @media (min-width: 681px) {
    .explore-bar, .mob-tab-list { display: none !important; }
  }
</style>

<div class="portal" id="sabm-portal">

  <div class="top-bar">
    <a href="/" class="top-bar-back" aria-label="Back to Registry">←</a>
    <a href="/" class="top-bar-title">South African Botanical Registry</a>
  </div>

  <div class="plant-band">
    <h1 class="plant-name">{d.name}</h1>
    <p class="plant-sci">{d.scientific_name}</p>
    <div class="tabs-row" role="tablist">
      {TABS.map(tab => (
        <button class={`tab-btn${tab.id === 'datasheet' ? ' active' : ''}`} data-id={tab.id} role="tab" aria-selected={tab.id === 'datasheet' ? 'true' : 'false'} aria-controls={`panel-${tab.id}`}>
          {tab.label}
        </button>
      ))}
    </div>
  </div>

  <div class="explore-bar" id="mob-bar">
    <span style="opacity:0;font-family:sans-serif;font-size:8px;">← back</span>
    <span style="flex:1;display:flex;justify-content:center;">
      <span class="explore-pill" id="mob-explore-btn">Explore <span class="pill-arrow">↓</span></span>
    </span>
  </div>

  <div class="mob-tab-list" id="mob-tab-list" style="display:none;">
    {TABS.map(tab => (
      <button class={`mob-tab-row${tab.id === 'datasheet' ? ' ds' : ''}`} data-id={tab.id}>{tab.label}</button>
    ))}
  </div>

  <div class="content-wrap" id="content-wrap" style="padding-bottom:60px;">

    <div class="tab-panel active" id="panel-datasheet">
      <div class="ds-grid">

        <div class="ds-left">
          <div class="carousel-wrap" id="carousel-wrap">
            {images.length > 0 ? (
              images.map((img, i) => (
                <img src={img.src} alt={`${d.name} — photograph ${i + 1}`} class={`carousel-img${i === 0 ? ' active' : ''}`} data-index={i} loading="lazy" />
              ))
            ) : (
              <span class="carousel-empty">Plant photography<br/>coming soon</span>
            )}
          </div>
          <div class="photo-credit">
            <div class="photo-credit-lbl">Photo Credit</div>
            <div class="photo-credit-val">
              {images.length > 0 && images[0].credit ? images[0].credit : 'John van der Berg · Cederberg Nature Reserve · March 2024'}
            </div>
          </div>
          <div class="carousel-nav">
            <button class="c-arrow" id="c-prev" aria-label="Previous">←</button>
            <span class="c-count" id="c-count">1 of {images.length > 0 ? images.length : 1}</span>
            <button class="c-arrow" id="c-next" aria-label="Next">→</button>
          </div>
          <div class="names-wrap">
            <div class="names-lbl">Common Names</div>
            {displayNames.map(([lang, name]) => (
              <div class="name-row">
                <div class="n-lang">{lang}</div>
                <div class={`n-val${(name as string) === 'not documented' || (name as string) === 'not documented in surviving records' ? ' nd' : ''}`}>{name as string}</div>
              </div>
            ))}
          </div>
        </div>

        <div class="ds-right">
          <div class="id-three">
            <div class="id-cell">
              <div class="block-lbl">Common Name</div>
              <div class="id-val">{d.name}</div>
            </div>
            <div class="id-cell">
              <div class="block-lbl">Scientific Name</div>
              <div class="id-val it">{d.scientific_name}</div>
            </div>
            <div class="id-cell">
              <div class="block-lbl">Family</div>
              <div class="id-val">{d.family ?? '—'}</div>
            </div>
          </div>

          <div class="native-block">
            <div class="block-lbl">Native Region</div>
            <div class="native-val">{d.native_region ?? '—'}</div>
          </div>

          <div class="stats-map-row">
            <div class="stats-col">
              <div class="stats-row">
                <div class="stat-cell">
                  <div class="block-lbl">Annual<br/>Production</div>
                  <div class="stat-val">{stats.production}</div>
                </div>
                <div class="stat-cell">
                  <div class="block-lbl">Export Revenue</div>
                  <div class="stat-val">{stats.revenue}</div>
                </div>
                <div class="stat-cell">
                  <div class="block-lbl">Export Markets</div>
                  <div class="stat-val">{stats.markets}</div>
                </div>
                <div class="stat-cell">
                  <div class="block-lbl">Livelihoods</div>
                  <div class="stat-val">{stats.livelihoods}</div>
                </div>
              </div>
              <div class="prot-block">
                <div class="prot-block-lbl">Protection &amp; Benefit Sharing</div>
                <div class="prot-row">
                  <span class="prot-badge">{protection.gi_year}</span>
                  <span class="prot-text">{protection.gi_status}</span>
                </div>
                <div class="prot-row">
                  <span class="prot-badge">{protection.bsa_year}</span>
                  <span class="prot-text">{protection.bsa_status}</span>
                </div>
                <div class="prot-row">
                  <span class="prot-badge">Organic</span>
                  <span class="prot-text">{protection.organic}</span>
                </div>
                <div class="prot-row">
                  <span class="prot-badge">Wild Harvest</span>
                  <span class="prot-text">{protection.wild_harvest}</span>
                </div>
              </div>
            </div>
            <div class="map-col">
              <ProvinceMap slug={slug} />
            </div>
            <div class="key-col">
              <div class="key-section-lbl">Provinces</div>
              <div class="key-prov-row"><span class="key-swatch" style="background:#2A5A40"></span><span class="key-abbr">EC</span><span class="key-name">Eastern Cape</span></div>
              <div class="key-prov-row"><span class="key-swatch" style="background:#6A9E82"></span><span class="key-abbr">FS</span><span class="key-name">Free State</span></div>
              <div class="key-prov-row"><span class="key-swatch" style="background:#C2D4CA"></span><span class="key-abbr">GT</span><span class="key-name">Gauteng</span></div>
              <div class="key-prov-row"><span class="key-swatch" style="background:#E4EDE8"></span><span class="key-abbr">KZN</span><span class="key-name">KwaZulu-Natal</span></div>
              <div class="key-prov-row"><span class="key-swatch" style="background:#EDE9E0"></span><span class="key-abbr">LIM</span><span class="key-name">Limpopo</span></div>
              <div class="key-prov-row"><span class="key-swatch" style="background:#E8DFC8"></span><span class="key-abbr">MP</span><span class="key-name">Mpumalanga</span></div>
              <div class="key-prov-row"><span class="key-swatch" style="background:#DDD0B0"></span><span class="key-abbr">NC</span><span class="key-name">Northern Cape</span></div>
              <div class="key-prov-row"><span class="key-swatch" style="background:#D4C598"></span><span class="key-abbr">NW</span><span class="key-name">North West</span></div>
              <div class="key-prov-row"><span class="key-swatch" style="background:#C8BA88"></span><span class="key-abbr">WC</span><span class="key-name">Western Cape</span></div>
              <div class="key-divider"></div>
              <div class="key-section-lbl">Key</div>
              <div class="key-dot-row"><span class="key-dot"></span><span class="key-name">Registered farm</span></div>
              <div class="key-dot-row"><span class="key-dot-org"><span class="key-dot-inner"></span></span><span class="key-name">Certified organic</span></div>
            </div>
          </div>

          {d.introduction && (
            <div class="intro-block">
              <div class="block-lbl">Introduction</div>
              <p class="intro-text">{d.introduction}</p>
            </div>
          )}
        </div>
      </div>

      <div class="ds-lower">
        {(m.active_compounds?.length || m.traditional_uses?.length || m.clinically_validated?.length) && (
          <div class="ds-row3">
            {m.active_compounds?.length && (
              <div class="ds-sec">
                <div class="ds-sec-lbl">Active Compounds</div>
                <ul class="ds-list">{m.active_compounds.map((c: string) => <li>{c}</li>)}</ul>
              </div>
            )}
            {m.traditional_uses?.length && (
              <div class="ds-sec">
                <div class="ds-sec-lbl">Traditional Uses</div>
                <ul class="ds-list">{m.traditional_uses.map((u: string) => <li>{u}</li>)}</ul>
              </div>
            )}
            {m.clinically_validated?.length && (
              <div class="ds-sec">
                <div class="ds-sec-lbl">Clinically Validated</div>
                <ul class="ds-list">{m.clinically_validated.map((v: string) => <li>{v}</li>)}</ul>
              </div>
            )}
          </div>
        )}

        {(cv.climate || cv.commercial) && (
          <div class="ds-row2">
            {(cv.climate || cv.regions) && (
              <div class="ds-sec">
                <div class="ds-sec-lbl">Cultivation</div>
                {cv.climate && <p class="ds-val" style="margin-bottom:5px">{cv.climate}</p>}
                {cv.regions && <p class="ds-val">{cv.regions}</p>}
              </div>
            )}
            {cv.commercial && (
              <div class="ds-sec">
                <div class="ds-sec-lbl">Commercial &amp; Trade Notes</div>
                <p class="ds-val">{cv.commercial}</p>
              </div>
            )}
          </div>
        )}

        {ik && (
          <div class="ik-block">
            <div class="ik-lbl">Indigenous Knowledge</div>
            <p class="ik-val">{ik}</p>
          </div>
        )}

        {d.naming_origins && (
          <div class="ds-sec" style="margin-bottom:14px;">
            <div class="ds-sec-lbl">Names &amp; Their Origins</div>
            <p class="ds-val" set:html={d.naming_origins}></p>
          </div>
        )}
      </div>
    </div>

    {TABS.filter(t => t.id !== 'datasheet').map(tab => (
      <div class="tab-panel" id={`panel-${tab.id}`}>
        <div class="cards-grid">
          {q[tab.id] ? (
            <>
              <div class="card">
                <div class="c-tag">{tab.label} · Free</div>
                <div class="c-hl" set:html={`"${q[tab.id]}"`}></div>
                <div class="c-tsr">Intelligence summary for {d.name}.</div>
                <div class="c-summary" id={`sum-${tab.id}-1`}>{d.introduction ?? 'Full summary available on request.'}</div>
                <div class="c-gate" id={`gate-${tab.id}-1`}>
                  <div class="c-email-row">
                    <input type="email" placeholder="your@email.com" id={`email-${tab.id}-1`} />
                    <button class="c-email-btn" data-send data-tab={tab.id} data-num="1">Send full article</button>
                  </div>
                  <div class="c-sent" id={`sent-${tab.id}-1`}>Link sent →</div>
                </div>
                <button class="c-read-btn" data-read data-tab={tab.id} data-num="1">Read summary ↓</button>
              </div>
              <div class="card dark">
                <div class="c-tag-l">{tab.label} · Free</div>
                <div class="c-hl-l">Intelligence bulletin — {d.name}</div>
                <div class="c-tsr-l">SABM Registry analysis.</div>
                <div class="c-summary-l" id={`sum-${tab.id}-2`}>{d.description ?? 'Full bulletin available on request.'}</div>
                <div class="c-gate" id={`gate-${tab.id}-2`}>
                  <div class="c-email-row">
                    <input type="email" placeholder="your@email.com" id={`email-${tab.id}-2`} class="dk" />
                    <button class="c-email-btn" data-send data-tab={tab.id} data-num="2">Send full article</button>
                  </div>
                  <div class="c-sent" id={`sent-${tab.id}-2`}>Link sent →</div>
                </div>
                <button class="c-read-btn" data-read data-tab={tab.id} data-num="2" style="color:#fff">Read summary ↓</button>
              </div>
            </>
          ) : (
            <div class="card">
              <div class="c-tag">{tab.label}</div>
              <div class="c-hl">Articles for {d.name} are being curated.</div>
              <div class="c-tsr">Subscribe to be notified when this section launches.</div>
            </div>
          )}
        </div>
      </div>
    ))}

  </div>

  <footer class="site-footer">
    <div class="ft-label">Connect with</div>
    <div class="ft-btns">
      <button class="ft-btn" id="btn-suppliers">Suppliers</button>
      <button class="ft-btn" id="btn-buyers">Buyers</button>
    </div>
  </footer>

  <div class="modal-overlay" id="modal-suppliers">
    <div class="modal">
      <button class="modal-close" data-close="suppliers">×</button>
      <h2>Connect with Suppliers</h2>
      <p>Tell us what you need. We will connect you with verified {d.name} suppliers in South Africa.</p>
      <form id="form-suppliers" action={FORMSPREE_CONNECT} method="POST">
        <input type="hidden" name="type" value="supplier-enquiry" />
        <input type="hidden" name="plant" value={d.name} />
        <div class="m-field"><label>Your Name</label><input type="text" name="name" required /></div>
        <div class="m-field"><label>Email</label><input type="email" name="email" required /></div>
        <div class="m-field"><label>Company</label><input type="text" name="company" /></div>
        <div class="m-field"><label>What you need</label><textarea name="message" placeholder="Quantity, product form, intended use…"></textarea></div>
        <button type="submit" class="m-submit">Send Enquiry →</button>
      </form>
      <div class="m-thanks" id="thanks-suppliers">Thank you — we will be in touch shortly.</div>
    </div>
  </div>

  <div class="modal-overlay" id="modal-buyers">
    <div class="modal">
      <button class="modal-close" data-close="buyers">×</button>
      <h2>Connect with Buyers</h2>
      <p>Register your interest. We will connect you with verified {d.name} buyers and market opportunities.</p>
      <form id="form-buyers" action={FORMSPREE_CONNECT} method="POST">
        <input type="hidden" name="type" value="buyer-enquiry" />
        <input type="hidden" name="plant" value={d.name} />
        <div class="m-field"><label>Your Name</label><input type="text" name="name" required /></div>
        <div class="m-field"><label>Email</label><input type="email" name="email" required /></div>
        <div class="m-field"><label>Company</label><input type="text" name="company" /></div>
        <div class="m-field"><label>What you offer</label><textarea name="message" placeholder="Volume, certifications, location…"></textarea></div>
        <button type="submit" class="m-submit">Send Enquiry →</button>
      </form>
      <div class="m-thanks" id="thanks-buyers">Thank you — we will be in touch shortly.</div>
    </div>
  </div>

</div>

<script is:inline>
(function () {
  const PLANT_ID  = document.querySelector('.plant-name')?.textContent?.trim() ?? 'plant';
  const LS_PREFIX = `sabm-${PLANT_ID}-`;
  function $(id) { return document.getElementById(id); }
  function lsGet(k) { try { return localStorage.getItem(LS_PREFIX + k); } catch { return null; } }
  function lsSet(k, v) { try { localStorage.setItem(LS_PREFIX + k, v); } catch {} }

  const dtabs   = document.querySelectorAll('.tab-btn');
  const dpanels = document.querySelectorAll('.tab-panel');
  function activateTab(id) {
    dtabs.forEach(t => { const on = t.dataset.id === id; t.classList.toggle('active', on); t.setAttribute('aria-selected', on ? 'true' : 'false'); });
    dpanels.forEach(p => p.classList.toggle('active', p.id === `panel-${id}`));
    $('content-wrap')?.scrollTo(0, 0);
  }
  dtabs.forEach(t => t.addEventListener('click', () => activateTab(t.dataset.id)));

  const mobBar     = $('mob-bar');
  const mobTabList = $('mob-tab-list');
  function setMobBar(state, label) {
    if (state === 'data') {
      mobBar.innerHTML = `<span style="opacity:0;font-family:sans-serif;font-size:8px;">← back</span><span style="flex:1;display:flex;justify-content:center;"><span class="explore-pill" id="mob-explore-btn">Explore <span class="pill-arrow">↓</span></span></span>`;
      $('mob-explore-btn')?.addEventListener('click', showTabs);
    } else if (state === 'tabs') {
      mobBar.innerHTML = `<span class="mob-back-txt" id="mob-back-data">← back</span><span style="flex:1;display:flex;justify-content:center;"><span class="explore-pill">Explore <span class="pill-arrow">↑</span></span></span>`;
      $('mob-back-data')?.addEventListener('click', showData);
    } else {
      mobBar.innerHTML = `<span class="mob-back-txt" id="mob-back-tabs">← back</span><span style="flex:1;display:flex;justify-content:center;"><span class="tab-pill">${label}</span></span>`;
      $('mob-back-tabs')?.addEventListener('click', showTabs);
    }
  }
  function showData() { mobTabList.style.display = 'none'; dpanels.forEach(p => p.classList.toggle('active', p.id === 'panel-datasheet')); setMobBar('data', ''); }
  function showTabs() { mobTabList.style.display = 'flex'; dpanels.forEach(p => p.classList.remove('active')); setMobBar('tabs', ''); }
  function showContent(id, label) { mobTabList.style.display = 'none'; dpanels.forEach(p => p.classList.toggle('active', p.id === `panel-${id}`)); setMobBar('content', label); $('content-wrap')?.scrollTo(0, 0); }
  document.querySelectorAll('.mob-tab-row').forEach(btn => {
    btn.addEventListener('click', () => { if (btn.dataset.id === 'datasheet') showData(); else showContent(btn.dataset.id, btn.textContent.trim()); });
  });

  const imgs = document.querySelectorAll('.carousel-img');
  const counter = $('c-count');
  let cIdx = 0;
  function showImg(i) { imgs.forEach((img, n) => img.classList.toggle('active', n === i)); if (counter) counter.textContent = `${i + 1} of ${imgs.length}`; cIdx = i; }
  $('c-prev')?.addEventListener('click', () => showImg((cIdx - 1 + imgs.length) % imgs.length));
  $('c-next')?.addEventListener('click', () => showImg((cIdx + 1) % imgs.length));

  document.querySelectorAll('[data-read]').forEach(btn => {
    const tab = btn.dataset.tab, num = btn.dataset.num, key = `read-${tab}-${num}`;
    if (lsGet(key)) { btn.textContent = 'Summary read ✓'; btn.classList.add('read'); $(`sum-${tab}-${num}`)?.classList.add('open'); $(`gate-${tab}-${num}`)?.classList.add('open'); }
    btn.addEventListener('click', () => {
      const s = $(`sum-${tab}-${num}`), g = $(`gate-${tab}-${num}`);
      const open = s?.classList.contains('open');
      if (!open) { s?.classList.add('open'); g?.classList.add('open'); btn.textContent = 'Summary read ✓'; btn.classList.add('read'); lsSet(key, '1'); }
      else { s?.classList.remove('open'); g?.classList.remove('open'); }
    });
  });

  document.querySelectorAll('[data-send]').forEach(btn => {
    btn.addEventListener('click', () => {
      const tab = btn.dataset.tab, num = btn.dataset.num;
      const inp = $(`email-${tab}-${num}`), sent = $(`sent-${tab}-${num}`);
      if (!inp) return;
      if (inp.value.includes('@')) { inp.style.display = 'none'; btn.style.display = 'none'; if (sent) sent.style.display = 'block'; }
      else { inp.style.borderColor = '#B8860B'; inp.focus(); }
    });
  });

  $('btn-suppliers')?.addEventListener('click', () => $('modal-suppliers')?.classList.add('open'));
  $('btn-buyers')?.addEventListener('click', () => $('modal-buyers')?.classList.add('open'));
  document.querySelectorAll('[data-close]').forEach(btn => { btn.addEventListener('click', () => $(`modal-${btn.dataset.close}`)?.classList.remove('open')); });
  document.querySelectorAll('.modal-overlay').forEach(o => { o.addEventListener('click', e => { if (e.target === o) o.classList.remove('open'); }); });
  ['suppliers','buyers'].forEach(type => {
    $(`form-${type}`)?.addEventListener('submit', async e => {
      e.preventDefault();
      const form = e.target;
      try { await fetch(form.action, { method:'POST', body: new FormData(form), headers:{ Accept:'application/json' } }); } catch {}
      form.style.display = 'none';
      $(`thanks-${type}`).style.display = 'block';
    });
  });
})();
</script>

</Layout>
