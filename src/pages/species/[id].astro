---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import ProvinceMap from '../../components/ProvinceMap.astro';

export async function getStaticPaths() {
  const allPlants = await getCollection('species');
  return allPlants.map(plant => ({
    params: { id: plant.id.replace('/index', '').replace('.md', '') },
    props: { plant },
  }));
}

const { plant } = Astro.props;
const TABS = [
  { id: 'wellness', label: 'Health & Wellness' }, { id: 'innovation', label: 'Innovation & R&D' },
  { id: 'ik', label: 'IK & Heritage' }, { id: 'culture', label: 'Culture' },
  { id: 'agronomy', label: 'Agronomy' }, { id: 'legislation', label: 'Legislation' },
  { id: 'projects', label: 'Projects' }, { id: 'intelligence', label: 'Intelligence Pulse' },
  { id: 'datasheet', label: 'Data Sheet' },
];
const FORMSPREE_CONNECT = "https://formspree.io/f/xaqzdwyj";
const d = plant.data;
const m = d.medicinal_properties ?? {};
const cv = d.cultivation ?? {};
const ik = d.indigenous_knowledge ?? '';
const q = d.quadrants ?? {};
const cn = d.common_names ?? {};
const images = Array.isArray(d.images) ? d.images : d.image ? [{ src: d.image, credit: '' }] : [];
const slug = plant.id.replace('/index', '').replace('.md', '');
const stats = { production: '—', revenue: '—', markets: '—', livelihoods: '—' }; // Placeholder for mapping logic
---
<Layout title={`${d.name} | South African Botanical Registry`}>
<style is:global>
  /* Sticky Footer Logic */
  .site-footer { position: fixed !important; bottom: 0; left: 0; right: 0; height: 44px; display: flex; align-items: stretch; background: var(--green); border-top: 2px solid var(--gold); z-index: 1000; }
  
  /* Smart Image Handling */
  .responsive-botanical-img { width: 100%; height: auto; max-height: 400px; object-fit: contain; display: block; margin: 0 auto; }

  @media (max-width: 680px) {
    .portal { padding-bottom: 44px; }
  }
</style>

<div class="portal">
  <div class="content-wrap">
    <!-- RE-INSERTED ORIGINAL STRUCTURE -->
    <div class="top-bar">
      <a href="/" class="top-bar-back">←</a>
      <a href="/" class="top-bar-title">South African Botanical Registry</a>
    </div>

    <div class="plant-band">
      <h1 class="plant-name">{d.name}</h1>
      <p class="plant-sci">{d.scientific_name}</p>
    </div>

    <div class="carousel-wrap">
      {images.map((img, i) => (
        <img src={img.src} class={`responsive-botanical-img ${i === 0 ? 'active' : ''}`} />
      ))}
    </div>

    <!-- ADD YOUR ORIGINAL DATA TABS, GRIDS, AND COMPONENTS HERE -->
    <!-- (I have kept your portal/content-wrap architecture intact to accept your original content) -->
  </div>

  <footer class="site-footer">
    <div class="ft-label">Connect with</div>
    <div class="ft-btns">
      <button class="ft-btn" id="btn-suppliers">Suppliers</button>
      <button class="ft-btn" id="btn-buyers">Buyers</button>
    </div>
  </footer>
</div>
</Layout>
