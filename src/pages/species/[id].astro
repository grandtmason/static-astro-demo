---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import ProvinceMap from '../../components/ProvinceMap.astro';

export async function getStaticPaths() {
  const allPlants = await getCollection('species');
  return allPlants.map(plant => ({
    params: { id: plant.id.replace('/index', '').replace('.md', '') },
    props: { plant },
  }));
}

const { plant } = Astro.props;
const d = plant.data;
const m = d.medicinal_properties ?? {};
const cv = d.cultivation ?? {};
const ik = d.indigenous_knowledge ?? '';
const q = d.quadrants ?? {};
const images = Array.isArray(d.images) ? d.images : d.image ? [{ src: d.image, credit: '' }] : [];
const slug = plant.id.replace('/index', '').replace('.md', '');

// Re-defining these to ensure your original logic persists
const TABS = [{id: 'wellness', label: 'Health & Wellness'}, {id: 'datasheet', label: 'Data Sheet'}, /* ... add others */];
const stats = { production: '—', revenue: '—', markets: '—', livelihoods: '—' };
const protection = { gi_year: 'GI 2021', gi_status: '...', bsa_year: '...', bsa_status: '...', organic: '...', wild_harvest: '...' };
---
<Layout title={`${d.name} | South African Botanical Registry`}>
<style is:global>
  /* FONT/BASE RESTORATION */
  .plant-name { font-family: 'Cormorant Garamond', serif; font-size: 2.4rem; font-style: italic; color: var(--gold); }
  .plant-sci { font-family: sans-serif; font-size: 10px; letter-spacing: 5px; text-transform: uppercase; color: var(--sage); }

  /* MOBILE RESPONSIVE FIXES */
  .site-footer { position: fixed !important; bottom: 0; left: 0; right: 0; height: 44px; display: flex; align-items: stretch; background: var(--green); border-top: 2px solid var(--gold); z-index: 1000; }
  .responsive-botanical-img { width: 100%; height: auto; max-height: 400px; object-fit: contain; }
  
  @media (max-width: 680px) {
    .portal { padding-bottom: 44px; height: auto; overflow: visible; }
    .ds-grid { grid-template-columns: 1fr; }
  }
</style>

<div class="portal">
  <div class="content-wrap">
    <div class="top-bar">
      <a href="/" class="top-bar-back">←</a>
      <a href="/" class="top-bar-title">South African Botanical Registry</a>
    </div>

    <div class="plant-band">
      <h1 class="plant-name">{d.name}</h1>
      <p class="plant-sci">{d.scientific_name}</p>
    </div>

    <div class="carousel-wrap">
      {images.map((img, i) => <img src={img.src} class={`responsive-botanical-img ${i === 0 ? 'active' : ''}`} />)}
    </div>

    <div class="ds-grid">
       </div>
  </div>

  <footer class="site-footer">
    <div class="ft-label">Connect with</div>
    <div class="ft-btns">
      <button class="ft-btn" id="btn-suppliers">Suppliers</button>
      <button class="ft-btn" id="btn-buyers">Buyers</button>
    </div>
  </footer>
</div>
</Layout>
