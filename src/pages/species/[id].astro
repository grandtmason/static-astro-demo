---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import ProvinceMap from '../../components/ProvinceMap.astro';

export async function getStaticPaths() {
  const allPlants = await getCollection('species');
  return allPlants.map(plant => ({
    params: { id: plant.id.replace('/index', '').replace('.md', '') },
    props: { plant },
  }));
}

const { plant } = Astro.props;

const TABS = [
  { id: 'wellness',      label: 'Health & Wellness'  },
  { id: 'innovation',    label: 'Innovation & R&D'   },
  { id: 'ik',            label: 'IK & Heritage'      },
  { id: 'culture',       label: 'Culture'            },
  { id: 'agronomy',      label: 'Agronomy'           },
  { id: 'legislation',   label: 'Legislation'        },
  { id: 'projects',      label: 'Projects'           },
  { id: 'intelligence',  label: 'Intelligence Pulse' },
  { id: 'datasheet',     label: 'Data Sheet'         },
];

const FORMSPREE_CONNECT = "https://formspree.io/f/xaqzdwyj";

const d = plant.data;
const m = d.medicinal_properties ?? {};
const cv = d.cultivation ?? {};
const ik = d.indigenous_knowledge ?? '';
const q = d.quadrants ?? {};
const cn = d.common_names ?? {};

const images: { src: string; credit: string }[] = Array.isArray(d.images)
  ? d.images
  : d.image
    ? [{ src: d.image, credit: '' }]
    : [];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Thing',
  name: d.name,
  alternateName: d.scientific_name,
  description: d.description,
  image: `https://southafricanbotanical.org.za${d.image ?? ''}`,
  url: `https://southafricanbotanical.org.za/species/${plant.id}`,
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': `https://southafricanbotanical.org.za/species/${plant.id}`,
  },
};

const sortedNames = Object.entries(cn).sort(([a], [b]) => a.localeCompare(b));

const COMMON_NAMES: Record<string, Record<string, string>> = {
  /* ... (Your original huge COMMON_NAMES object) ... */
};

const PLANT_STATS: Record<string, { production: string; revenue: string; markets: string; livelihoods: string }> = {
  /* ... (Your original huge PLANT_STATS object) ... */
};

const PLANT_PROTECTION: Record<string, { gi_year: string; gi_status: string; bsa_year: string; bsa_status: string; organic: string; wild_harvest: string }> = {
  /* ... (Your original huge PLANT_PROTECTION object) ... */
};

const slug = plant.id.replace('/index', '').replace('.md', '');
const hardcodedNames = COMMON_NAMES[slug] ?? {};
const displayNames = Object.keys(hardcodedNames).length > 0 ? Object.entries(hardcodedNames) : sortedNames;
const stats = PLANT_STATS[slug] ?? { production: '—', revenue: '—', markets: '—', livelihoods: '—' };
const protection = PLANT_PROTECTION[slug] ?? { gi_year: 'GI 2021', gi_status: 'EU Geographical Indication — South Africa sole legally recognised producer.', bsa_year: 'BSA 2019', bsa_status: 'Khoisan Benefit-Sharing Agreement — ongoing royalties paid to traditional knowledge holders.', organic: '35% of total production certified organic.', wild_harvest: 'Fully cultivated — no wild harvest.' };
---

<Layout title={`${d.name} | South African Botanical Registry`} schema={jsonLd}>
<style>
  /* ... (Your original long stylesheet) ... */
</style>

<div class="portal" id="sabm-portal">
    </div>

<script is:inline>
(function () {
  /* ... (Your original complex JS initialization) ... */
})();
</script>
</Layout>
