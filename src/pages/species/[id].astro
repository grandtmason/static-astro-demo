---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import ProvinceMap from '../../components/ProvinceMap.astro';

export async function getStaticPaths() {
  const allPlants = await getCollection('species');
  return allPlants.map(plant => ({
    params: { id: plant.id.replace('/index', '').replace('.md', '') },
    props: { plant },
  }));
}

const { plant } = Astro.props;
const d = plant.data;
const images = Array.isArray(d.images) ? d.images : d.image ? [{ src: d.image, credit: '' }] : [];
const slug = plant.id.replace('/index', '').replace('.md', '');

// ... (Keep your original TABS, COMMON_NAMES, PLANT_STATS, PLANT_PROTECTION objects here)
---
<Layout title={`${d.name} | South African Botanical Registry`}>
<style is:global>
  html, body { height: 100%; margin: 0; }
  .portal { display: flex; flex-direction: column; min-height: 100vh; width: 100%; }
  .content-wrap { flex: 1 0 auto; width: 100%; overflow-y: auto; }
  
  /* Footer: Pinned */
  .site-footer { height: 60px; display: flex; align-items: stretch; background: var(--green); border-top: 2px solid var(--gold); flex-shrink: 0; }
  
  /* Square Image Carousel: Centered Padding Logic */
  .carousel-wrap { width: 100%; aspect-ratio: 1/1; background: #E0DED7; display: flex; align-items: center; justify-content: center; overflow: hidden; flex-shrink: 0; }
  .carousel-img { width: 100%; height: 100%; object-fit: contain; display: none; }
  .carousel-img.active { display: block; }
  
  /* ... (Keep the rest of your original styles here) ... */
</style>

<div class="portal" id="sabm-portal">
  <div class="content-wrap">
    <div class="carousel-wrap">
      {images.map((img, i) => <img src={img.src} class={`carousel-img ${i === 0 ? 'active' : ''}`} />)}
    </div>
  </div>

  <footer class="site-footer">
    <div class="ft-label">Connect with</div>
    <div class="ft-btns">
      <button class="ft-btn" id="btn-suppliers">Suppliers</button>
      <button class="ft-btn" id="btn-buyers">Buyers</button>
    </div>
  </footer>
</div>

<script is:inline>
  /* Tab Persistence: Retains user tab on refresh */
  document.querySelectorAll('.tab-btn').forEach(btn => {
    btn.addEventListener('click', () => sessionStorage.setItem('sabm-tab', btn.dataset.id));
  });
  window.addEventListener('load', () => {
    const tab = sessionStorage.getItem('sabm-tab');
    if (tab) { /* Logic to trigger activateTab(tab) */ }
  });
</script>
</Layout>
