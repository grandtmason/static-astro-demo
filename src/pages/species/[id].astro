---
<Layout title={`${d.name} | South African Botanical Registry`}>
<style is:global>
  .portal { display: flex; flex-direction: column; height: 100vh; }
  .content-wrap { flex: 1; overflow-y: auto; padding-bottom: 60px; }
  
  /* Sticky Buyer/Seller Footer */
  .site-footer { height: 60px; display: flex; align-items: stretch; background: var(--green); border-top: 2px solid var(--gold); position: fixed; bottom: 0; width: 100%; z-index: 1000; }
  .ft-label { font-family: sans-serif; font-size: 10px; color: var(--sage); padding: 0 20px; display: flex; align-items: center; border-right: 1px solid var(--gold); }
  .ft-btns { display: flex; flex: 1; }
  .ft-btn { flex: 1; border: none; background: transparent; color: var(--gold); font-family: sans-serif; font-size: 10px; cursor: pointer; }

  /* Square Image Carousel Logic */
  .carousel-wrap { width: 100%; aspect-ratio: 1/1; background: #eee; display: flex; align-items: center; justify-content: center; overflow: hidden; }
  .carousel-img { width: 100%; height: 100%; object-fit: contain; } /* 'contain' centers & pads automatically */
</style>

<div class="portal">
  <div class="content-wrap">
    <div class="carousel-wrap">
      {images.map((img, i) => <img src={img.src} class={`carousel-img ${i === 0 ? 'active' : ''}`} />)}
    </div>
    </div>

  <footer class="site-footer">
    <div class="ft-label">Connect with:</div>
    <div class="ft-btns">
      <button class="ft-btn" id="btn-suppliers">Suppliers</button>
      <button class="ft-btn" id="btn-buyers">Buyers</button>
    </div>
  </footer>
</div>

<script is:inline>
  /* Tab Persistence: Save tab to sessionStorage on click */
  document.querySelectorAll('.tab-btn').forEach(btn => {
    btn.addEventListener('click', () => sessionStorage.setItem('sabm-tab', btn.dataset.id));
  });
  /* Restore tab on load */
  window.addEventListener('load', () => {
    const savedTab = sessionStorage.getItem('sabm-tab');
    if (savedTab) { activateTab(savedTab); }
  });
</script>
</Layout>
