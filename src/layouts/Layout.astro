---
interface Props { title: string; schema?: object; }
const { title, schema } = Astro.props;
---
<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>{title}</title>
		{schema && <script type="application/ld+json" set:html={JSON.stringify(schema)} />}
	</head>
	<body>
		<slot />
		<script is:inline>
			/* Navigation memory: Saves scroll position on link click */
			document.addEventListener('click', function(e) {
				const link = e.target.closest('a.plant-card');
				if (link) { sessionStorage.setItem('registryScroll', window.scrollY); }
			});
			/* Restore scroll on return */
			window.addEventListener('pageshow', () => {
				const pos = sessionStorage.getItem('registryScroll');
				if (pos) { window.scrollTo(0, parseInt(pos)); }
			});
		</script>
	</body>
</html>
<style is:global>
	:root { --parchment: #F9F8F4; --ink: #2F2F2F; --gold: #B8860B; --green: #1A3A2A; --sage: #9DB8A8; }
	html, body { font-family: 'EB Garamond', Georgia, serif; background: var(--parchment); color: var(--ink); margin: 0; padding: 0; height: 100%; }
</style>
