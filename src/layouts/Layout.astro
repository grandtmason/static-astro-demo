---
interface Props { title: string; schema?: object; }
const { title, schema } = Astro.props;
---
<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=0" />
		<title>{title}</title>
		{schema && <script type="application/ld+json" set:html={JSON.stringify(schema)} />}
	</head>
	<body>
		<slot />
		<script is:inline>
			if ('scrollRestoration' in history) { history.scrollRestoration = 'manual'; }
		</script>
	</body>
</html>
<style is:global>
	:root { --parchment: #F9F8F4; --ink: #2F2F2F; --gold: #B8860B; --green: #1A3A2A; --sage: #9DB8A8; }
	html, body { font-family: 'EB Garamond', Georgia, serif; background: var(--parchment); color: var(--ink); margin: 0; padding: 0; height: 100%; }
	.responsive-botanical-img { width: 100%; height: auto; object-fit: contain; display: block; }
</style>
