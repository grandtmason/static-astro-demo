---
interface Props {
	title: string;
	schema?: object;
}
const { title, schema } = Astro.props;
---
<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="The South African Botanical Registry — South Africa's authoritative scientific registry for 24 indigenous botanical species." />
		<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<meta name="google-site-verification" content="K6KrNQwbkgpWH4vs3TIMlx1L50BYIIFeZ4doCInWhzM" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=EB+Garamond:ital,wght@0,400;0,500;1,400&display=swap" rel="stylesheet" />
		<title>{title}</title>
		{schema && <script type="application/ld+json" set:html={JSON.stringify(schema)} />}
	</head>
	<body>
		<slot />
		<script is:inline>
			if ('scrollRestoration' in history) { history.scrollRestoration = 'manual'; }
			window.addEventListener('pageshow', () => {
				const savedPosition = sessionStorage.getItem('registryScroll');
				if (savedPosition) {
					sessionStorage.removeItem('registryScroll');
					window.addEventListener('load', function() {
						setTimeout(function() { window.scrollTo({ top: parseInt(savedPosition), behavior: 'instant' }); }, 100);
					});
				}
			});
			document.addEventListener('click', function(e) {
				const link = e.target.closest('a.plant-card');
				if (link) { sessionStorage.setItem('registryScroll', window.scrollY); }
			});
		</script>
	</body>
</html>
<style is:global>
	:root { --parchment: #F9F8F4; --ink: #2F2F2F; --gold: #B8860B; --green: #1A3A2A; --sage: #9DB8A8; }
	html, body {
		font-family: 'EB Garamond', Georgia, serif;
		background: var(--parchment);
		color: var(--ink);
		margin: 0;
		padding: 0;
		height: 100%;
	}
    /* Global Image Handling: preserves native aspect ratio without distortion */
	.responsive-botanical-img {
		width: 100%;
		height: auto;
		object-fit: contain;
		display: block;
	}
</style>
