<script define:vars={{ activeJSON }}>
  const active = JSON.parse(activeJSON);
  const allIds = ['EC','FS','GT','KZN','LIM','MP','NC','NW','WC'];
  allIds.forEach(id => {
    const g = document.getElementById('prov-' + id);
    if (!g) return;
    if (!active.includes(id)) {
