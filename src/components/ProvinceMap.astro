---
import topoData from "../data/za-provinces.topojson";
import farmData from "../data/farms.json";
import { getCoords } from "../utils/mapCoords";

const { slug } = Astro.props;

// Accessing raw TopoJSON layers without external libraries
const layerKey = Object.keys(topoData.objects)[0];
const geometries = topoData.objects[layerKey].geometries;

const getMarkerColor = (type: string) => {
  const colors: Record<string, string> = {
    'organic': '#77DD77',
    'commercial': '#FDFD96',
    'wild': '#A8E4A0',
    'small-scale': '#FFB347'
  };
  return colors[type] ?? '#808080';
};
---

<div class="map-wrapper">
  <svg viewBox="0 0 800 600" class="map-container" preserveAspectRatio="xMidYMid meet">
    {geometries.map((geo: any) => {
      const code = geo.properties?.CODE ?? 'UNKNOWN';
      const colorMap: Record<string, string> = {
        'EC': '#2A5A40', 'FS': '#6A9983', 'GT': '#BCCEC6', 
        'KZN': '#E1E9E6', 'LIM': '#E6E3DE', 'MP': '#DED3C4', 
        'NC': '#D2C1A8', 'NW': '#CBB892', 'WC': '#C3B386'
      };
      
      return (
        <path
          d={geo.arcs} 
          fill={colorMap[code] ?? '#f4f4f4'}
          stroke="white"
          stroke-width="1"
        />
      );
    })}

    {farmData.filter((f: any) => f.plant === slug).map((farm: any) => {
      const coords = getCoords(farm.provinceCode);
      return coords ? (
        <circle 
          cx={coords.x} cy={coords.y} r="15" 
          fill={getMarkerColor(farm.type)} 
          stroke="black" stroke-width="2" 
        />
      ) : null;
    })}
  </svg>
</div>

<style>
  .map-wrapper { background-color: #f0f4f8; padding: 20px; border-radius: 8px; }
  .map-container { width: 100%; height: auto; background-color: #fafafa; }
</style>
