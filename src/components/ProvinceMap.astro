---
import { feature } from "topojson-client";
import topoData from "../data/za-provinces.topojson";
// Ensure these files exist and are correctly referenced
const provinceData = feature(topoData, topoData.objects.layer1);
---

<div class="map-wrapper">
  <svg viewBox="0 0 800 600" style="width: 100%; height: auto;">
    {provinceData.features.map((feature: any) => (
      <path
        d={feature.geometry.coordinates}
        fill="#ccc"
        stroke="white"
        stroke-width="0.5"
      />
    ))}
  </svg>
</div>
