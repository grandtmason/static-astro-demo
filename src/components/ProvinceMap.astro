---
import { feature } from "topojson-client";
import { geoPath, geoIdentity } from "d3-geo";
import topoData from "../data/za-provinces.topojson";
import { getCoords } from "../utils/mapCoords";
import farmData from "../data/farms.json";

// Safely extract features, handle potential null/undefined
const provinceData = topoData ? feature(topoData, topoData.objects.layer1) : { features: [] };
const { slug } = Astro.props;

// Use a simpler projection setup
const pathGenerator = geoPath().projection(geoIdentity().reflectY(true));

const getMarkerColor = (type: string) => {
  const colors: Record<string, string> = {
    'organic': '#77DD77',
    'commercial': '#FDFD96',
    'wild': '#A8E4A0',
    'small-scale': '#FFB347'
  };
  return colors[type] || '#808080';
};
---

<div class="map-wrapper">
  <svg viewBox="0 0 800 600" class="map-container">
    {provinceData.features.map((feature: any) => {
      const colorMap: Record<string, string> = {
        'EC': '#2A5A40', 'FS': '#6A9983', 'GT': '#BCCEC6', 
        'KZN': '#E1E9E6', 'LIM': '#E6E3DE', 'MP': '#DED3C4', 
        'NC': '#D2C1A8', 'NW': '#CBB892', 'WC': '#C3B386'
      };
      
      const pathData = pathGenerator(feature);
      // Only render if pathData exists to prevent build crashes
      return pathData ? (
        <path
          d={pathData}
          fill={colorMap[feature.properties?.CODE] || '#f4f4f4'}
          stroke="white"
          stroke-width="0.5"
        />
      ) : null;
    })}

    {Array.isArray(farmData) && farmData.filter((f: any) => f.plant === slug).map((farm: any) => {
      const coords = getCoords(farm.provinceCode);
      return coords ? (
        <circle cx={coords.x} cy={coords.y} r="8" fill={getMarkerColor(farm.type)} stroke="black" stroke-width="1" />
      ) : null;
    })}
  </svg>
</div>

<style>
  .map-wrapper { background-color: #f0f4f8; padding: 20px; border-radius: 8px; }
  .map-container { width: 100%; height: auto; background-color: #fafafa; }
</style>
