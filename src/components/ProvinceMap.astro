---
import { feature } from "topojson-client";
import { geoPath, geoIdentity } from "d3-geo";
import topoData from "../data/za-provinces.topojson";
import { getCoords } from "../utils/mapCoords";
import farmData from "../data/farms.json";

const provinceData = feature(topoData, topoData.objects.layer1);
const { slug } = Astro.props;

// Re-added path generator to convert coordinate arrays into path strings
const pathGenerator = geoPath().projection(geoIdentity().reflectY(true));

const getMarkerColor = (type: string) => {
  switch (type) {
    case 'organic': return '#77DD77';
    case 'commercial': return '#FDFD96';
    case 'wild': return '#A8E4A0';
    case 'small-scale': return '#FFB347';
    default: return '#808080';
  }
};
---

<div class="map-wrapper">
  <svg viewBox="0 0 800 600" class="map-container">
    {provinceData.features.map((feature: any) => {
      const colorMap: Record<string, string> = {
        'EC': '#2A5A40', 'FS': '#6A9983', 'GT': '#BCCEC6', 
        'KZN': '#E1E9E6', 'LIM': '#E6E3DE', 'MP': '#DED3C4', 
        'NC': '#D2C1A8', 'NW': '#CBB892', 'WC': '#C3B386'
      };
      return (
        <path
          d={pathGenerator(feature) || ""}
          fill={colorMap[feature.properties.CODE] || '#f4f4f4'}
          stroke="white"
          stroke-width="0.5"
        />
      );
    })}

    {farmData.filter((f: any) => f.plant === slug).map((farm: any) => {
      const { x, y } = getCoords(farm.provinceCode);
      return (
        <circle cx={x} cy={y} r="8" fill={getMarkerColor(farm.type)} stroke="black" stroke-width="1" />
      );
    })}
  </svg>
</div>

<style>
  .map-wrapper { background-color: #f0f4f8; padding: 20px; border-radius: 8px; }
  .map-container { width: 100%; height: auto; background-color: #fafafa; }
</style>
