---
// This version works without any external tools (no npm/package.json needed)
import topoData from "../data/za-provinces.topojson";
import { getCoords } from "../utils/mapCoords";
import farmData from "../data/farms.json";

const { slug } = Astro.props;

// Helper to pick marker color
const getMarkerColor = (type: string) => {
  switch (type) {
    case 'organic': return '#77DD77';
    case 'commercial': return '#FDFD96';
    case 'wild': return '#A8E4A0';
    case 'small-scale': return '#FFB347';
    default: return '#D3D3D3';
  }
};
---

<div class="map-wrapper">
  <svg viewBox="-7 0 809 709" class="map-container" preserveAspectRatio="xMidYMid meet">
    {topoData.objects.layer1.geometries.map((geo: any) => {
      const colorMap: Record<string, string> = {
        'EC': '#2A5A40', 'FS': '#6A9983', 'GT': '#BCCEC6', 
        'KZN': '#E1E9E6', 'LIM': '#E6E3DE', 'MP': '#DED3C4', 
        'NC': '#D2C1A8', 'NW': '#CBB892', 'WC': '#C3B386'
      };
      return (
        <path
          d={geo.arcs} 
          fill={colorMap[geo.properties.CODE] || '#f4f4f4'}
          stroke="white"
          stroke-width="0.5"
        />
      );
    })}

    {farmData.filter(f => f.plant === slug).map(farm => {
      const { x, y } = getCoords(farm.provinceCode);
      return (
        <circle 
          cx={x} cy={y} r="12" 
          fill={getMarkerColor(farm.type)} 
          stroke="black" stroke-width="2" 
        />
      );
    })}
  </svg>
</div>

<style>
  .map-wrapper { background-color: #f0f4f8; padding: 20px; border-radius: 8px; }
  .map-container { width: 100%; height: auto; background-color: #fafafa; }
</style>
