---
import { feature } from "topojson-client";
import { geoPath, geoMercator } from "d3-geo";
import topoRaw from "../data/za-provinces.topojson?raw";
import farmRaw from "../data/farms.json?raw";
import configRaw from "../data/map-config.json?raw";

const { slug } = Astro.props;

const safeParse = (jsonStr: string, fallback: any) => {
  try {
    return jsonStr && jsonStr.trim() ? JSON.parse(jsonStr) : fallback;
  } catch {
    return fallback;
  }
};

const topoData = safeParse(topoRaw, { objects: {} });
const farmData = safeParse(farmRaw, []);
const mapConfig = safeParse(configRaw, { provinceColors: {}, markerStyles: {} });

const objectKey = topoData.objects ? Object.keys(topoData.objects)[0] : null;
const provinceData = objectKey ? feature(topoData, topoData.objects[objectKey]) : null;

const projection = provinceData ? geoMercator().fitSize([800, 700], provinceData) : null;
const pathGenerator = provinceData ? geoPath().projection(projection) : null;

// Dynamic filter: This will work for all 24 species in plant_registry.json
const filteredFarms = Array.isArray(farmData) 
  ? farmData.filter((f: any) => f.plant === slug) 
  : [];
---

<svg viewBox="0 0 800 700" class="map-container" preserveAspectRatio="xMidYMid meet">
  {provinceData && provinceData.features.map((feature: any) => (
    <path
      d={pathGenerator ? pathGenerator(feature) || "" : ""}
      fill={mapConfig.provinceColors[feature.properties.CODE] || "#f4f4f4"}
      stroke="white"
      stroke-width="0.5"
    />
  ))}

  {filteredFarms.map((farm: any) => {
    if (!projection) return null;
    const coords = projection([farm.lng, farm.lat]);
    if (!coords) return null;
    
    const [x, y] = coords;
    // Map markers dynamically based on type defined in farms.json
    const style = mapConfig.markerStyles[farm.type] || { fill: "#D3D3D3", stroke: "#000" };
    
    return (
      <circle 
        cx={x} cy={y} r="8" 
        fill={style.fill} 
        stroke={style.stroke} 
        stroke-width="2" 
      />
    );
  })}
</svg>

<style>
  .map-container { display: block; width: 100%; height: 100%; max-height: 280px; background-color: #fafafa; }
</style>
