---
import { feature } from "topojson-client";
import { geoPath, geoMercator } from "d3-geo";
// Use direct import for static assets to ensure build-time inclusion
import topoData from "../data/za-provinces.topojson";
import farmData from "../data/farms.json";
import mapConfig from "../data/map-config.json";

const { slug } = Astro.props;

// TopoJSON structure is now imported as a standard JS object
const objectKey = Object.keys(topoData.objects)[0];
const provinceData = feature(topoData, topoData.objects[objectKey]) as any;

const projection = geoMercator().fitSize([800, 700], provinceData);
const pathGenerator = geoPath().projection(projection);
const filteredFarms = farmData.filter(f => f.plant === slug);
---

<svg viewBox="0 0 800 700" class="map-container" preserveAspectRatio="xMidYMid meet">
  {provinceData.features.map((feature: any) => (
    <path
      d={pathGenerator(feature) || ""}
      fill={mapConfig.provinceColors[feature.properties.CODE] || "#f4f4f4"}
      stroke="white"
      stroke-width="0.5"
    />
  ))}

  {filteredFarms.map(farm => {
    const coords = projection([farm.lng, farm.lat]);
    if (!coords) return null;
    
    const [x, y] = coords;
    const style = mapConfig.markerStyles[farm.type] || { fill: "#D3D3D3", stroke: "#000" };
    
    return (
      <circle 
        cx={x} cy={y} r="8" 
        fill={style.fill} 
        stroke={style.stroke} 
        stroke-width="2" 
      />
    );
  })}
</svg>

<style>
  .map-container {
    display: block;
    width: 100%;
    height: 100%;
    max-height: 280px;
    background-color: #fafafa;
  }
</style>
