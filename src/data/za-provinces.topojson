---
// src/components/ProvinceMap.astro
import { feature } from "topojson-client";
import topoData from "../data/za-provinces.topojson";
import { getCoords } from "../utils/mapCoords";
import farmData from "../data/farms.json";

const provinceData = feature(topoData, topoData.objects.layer1);
const { slug } = Astro.props;

const getMarkerColor = (type: string) => {
  switch (type) {
    case 'organic': return '#77DD77';    // Pastel Green
    case 'commercial': return '#FDFD96'; // Pastel Yellow
    case 'wild': return '#A8E4A0';       // Deep Pastel Sage
    case 'small-scale': return '#FFB347';// Burnt Orange
    default: return '#808080';
  }
};
---

<div class="map-wrapper">
  <svg viewBox="-7 0 809 709" class="map-container">
    <!-- Render Provinces -->
    {provinceData.features.map((feature) => {
      const colorMap: Record<string, string> = {
        'EC': '#2A5A40', 'FS': '#6A9983', 'GT': '#BCCEC6', 
        'KZN': '#E1E9E6', 'LIM': '#E6E3DE', 'MP': '#DED3C4', 
        'NC': '#D2C1A8', 'NW': '#CBB892', 'WC': '#C3B386'
      };
      return (
        <path
          d={feature.geometry.coordinates}
          fill={colorMap[feature.properties.CODE] || '#f4f4f4'}
          stroke="white"
          stroke-width="0.5"
        />
      );
    })}

    <!-- Render Farm Icons -->
    {farmData.filter(f => f.plant === slug).map(farm => {
      const { x, y } = getCoords(farm.provinceCode);
      return (
        <circle 
          cx={x} cy={y} r="12" 
          fill={getMarkerColor(farm.type)} 
          stroke="black" stroke-width="2" 
        />
      );
    })}
  </svg>
</div>

<style>
  .map-wrapper {
    background-color: #f0f4f8; /* Light pastel blue ocean */
    padding: 20px;
    border-radius: 8px;
  }
  .map-container {
    width: 100%;
    height: auto;
    background-color: #fafafa; /* Off-white for non-SA territories */
  }
</style>
